generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id @default(uuid())
  idea         String
  requirements Json
  classes      Json
  sourceFiles  Json
  testFiles    Json
  review       Json
  createdAt    DateTime @default(now())
}