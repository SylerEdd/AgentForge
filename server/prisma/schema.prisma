generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String    @id @default(uuid())
  idea         String
  requirements Json
  classes      Json
  sourceFiles  Json
  testFiles    Json
  review       Json
  createdAt    DateTime  @default(now())
  testRuns     TestRun[]
}

model TestRun {
  id        String   @id @default(uuid())
  projectId String
  success   Boolean
  output    String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
